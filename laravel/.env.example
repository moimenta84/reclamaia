APP_NAME=ReclamaIA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Stripe
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# Python service
PYTHON_SERVICE_URL=http://localhost:8001
PYTHON_TIMEOUT_SECONDS=35
INTERNAL_API_SECRET=change-me-in-production

# Signaturit (firma digital eIDAS — poderes, autorizaciones, contratos)
SIGNATURIT_API_KEY=
SIGNATURIT_SANDBOX=true
SIGNATURIT_WEBHOOK_SECRET=

# Google Document AI (OCR avanzado para pólizas escaneadas, partes médicos)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=eu
GOOGLE_DOCAI_PROCESSOR_ID=

# Valoración de daños vehiculares (mock | dat | audatex | gt | solera)
DAMAGE_VALUATION_PROVIDER=mock
DAT_API_KEY=
AUDATEX_USERNAME=
AUDATEX_PASSWORD=
GT_API_KEY=

# Pricing
DOCUMENT_PRICE_CENTS=999
SUBSCRIPTION_PRICE_CENTS=2999

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=reclamaia
DB_USERNAME=reclamaia
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
